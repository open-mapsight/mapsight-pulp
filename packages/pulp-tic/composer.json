{
    "name": "mapsight/pulp-tic",
    "description": "Specialized handlers for parsing Traffic Information Center (TIC) XML data.",
    "type": "library",
    "keywords": [
        "mapsight",
        "pulp",
        "tic",
        "xml",
        "traffic",
        "parsing"
    ],
    "homepage": "https://github.com/open-mapsight/mapsight-pulp",
    "license": "MIT",
    "authors": [
        {
            "name": "Paul Golmann",
            "email": "mail@pje-web.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/open-mapsight/mapsight-pulp/issues",
        "source": "https://github.com/open-mapsight/mapsight-pulp/tree/main/packages/pulp-tic"
    },
    "require": {
        "php": "^8.2",
        "symfony/polyfill-php83": "^1.37",
        "symfony/polyfill-php84": "^1.37",
        "symfony/polyfill-php85": "^1.37",
        "mapsight/pulp": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mapsight/pulp-json": "*"
    },
    "autoload": {
        "psr-4": {
            "OpenMapsight\\pulptic\\": "src"
        },
        "classmap": [
            "PulpTIC.php"
        ]
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenMapsight\\pulptic\\dev\\": "src-dev"
        }
    },
    "scripts": {
        "test": "phpunit test/"
    },
    "archive": {
        "exclude": [
            "*",
            ".*",
            "!/src/*",
            "!/PulpTIC.php"
        ]
    }
}
