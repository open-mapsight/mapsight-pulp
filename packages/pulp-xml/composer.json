{
  "name": "mapsight/pulp-xml",
  "require": {
    "php": "^8.2",
    "symfony/polyfill-php83": "^1.37",
    "symfony/polyfill-php84": "^1.37",
    "symfony/polyfill-php85": "^1.37",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "mapsight/pulp": "*"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "OpenMapsight\\pulpxml\\": "src"
    },
    "classmap": [
      "PulpXML.php"
    ]
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    }
  },
  "archive": {
    "exclude": [
      "*",
      ".*",
      "!/src/*",
      "!/PulpXML.php"
    ]
  }
}
