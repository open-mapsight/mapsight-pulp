{
  "name": "mapsight/pulp-geocsv",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "symfony/polyfill-php83": "^1.37",
    "symfony/polyfill-php84": "^1.37",
    "symfony/polyfill-php85": "^1.37",
    "ext-json": "*",
    "mapsight/geojson-reproject": "*",
    "mapsight/pulp": "*",
    "phayes/geophp": "^1"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit test/"
  },
  "autoload": {
    "classmap": [
      "PulpGeoCSV.php"
    ],
    "psr-4": {
      "OpenMapsight\\pulpgeocsv\\": "src"
    }
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    }
  },
  "archive": {
    "exclude": [
      "*",
      ".*",
      "!/src/*",
      "!/PulpGeoCSV.php"
    ]
  }
}
