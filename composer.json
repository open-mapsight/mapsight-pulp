{
  "name": "mapsight/pulp-monorepo",
  "description": "Monorepo for Pulp packages",
  "type": "project",
  "license": "proprietary",
  "repositories": [
    {
      "type": "path",
      "url": "packages/*",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": "^8.2",
    "symfony/polyfill-php83": "^1.37",
    "symfony/polyfill-php84": "^1.37",
    "symfony/polyfill-php85": "^1.37",
    "mapsight/pulp": "@dev",
    "mapsight/pulp-concert": "@dev",
    "mapsight/pulp-geocsv": "@dev",
    "mapsight/pulp-geojson": "@dev",
    "mapsight/pulp-json": "@dev",
    "mapsight/pulp-soap": "@dev",
    "mapsight/pulp-tic": "@dev",
    "mapsight/pulp-xml": "@dev",
    "mapsight/geojson-reproject": "@dev"
  },
  "scripts": {
    "test": "php test.php"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "rector/rector": "^2.4"
  }
}
